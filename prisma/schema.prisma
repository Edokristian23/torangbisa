generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Blud {
  id                String             @id @default(cuid())
  code              String             @unique
  name              String             @unique
  region            String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  assessmentPeriods AssessmentPeriod[]
  users             User[]
}

model User {
  id                          String               @id @default(cuid())
  username                    String               @unique
  email                       String?              @unique
  name                        String
  password                    String
  role                        UserRole             @default(BLUD_OPERATOR)
  isActive                    Boolean              @default(true)
  mustChangePassword          Boolean              @default(false)
  failedLoginCount            Int                  @default(0)
  lockedUntil                 DateTime?
  lastLoginAt                 DateTime?
  passwordChangedAt           DateTime?
  bludId                      String?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  uploadedDocuments           AssessmentDocument[] @relation("DocumentUploader")
  reviewedAssessmentPeriods   AssessmentPeriod[]   @relation("AssessmentReviewer")
  submittedAssessmentPeriods  AssessmentPeriod[]   @relation("AssessmentSubmitter")
  reviewedAssessmentResponses AssessmentResponse[] @relation("AssessmentResponseReviewer")
  createdAuditLogs            AuditLog[]           @relation("AuditActor")
  createdFollowUpEntries      FollowUpEntry[]      @relation("FollowUpCreator")
  guideDocuments              GuideDocument[]      @relation("GuideDocumentUploader")
  blud                        Blud?                @relation(fields: [bludId], references: [id])
}

model AssessmentPeriod {
  id            String               @id @default(cuid())
  year          Int
  moduleKey     String
  status        AssessmentStatus     @default(DRAFT)
  bludId        String
  submittedAt   DateTime?
  submittedById String?
  reviewedAt    DateTime?
  reviewedById  String?
  reviewerNotes String?
  approvedAt    DateTime?
  rejectedAt    DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  documents     AssessmentDocument[]
  blud          Blud                 @relation(fields: [bludId], references: [id], onDelete: Cascade)
  reviewedBy    User?                @relation("AssessmentReviewer", fields: [reviewedById], references: [id])
  submittedBy   User?                @relation("AssessmentSubmitter", fields: [submittedById], references: [id])
  responses     AssessmentResponse[]

  @@unique([bludId, year, moduleKey])
  @@index([year, moduleKey])
  @@index([status, year])
  @@index([submittedById])
  @@index([reviewedById])
}

model AssessmentResponse {
  id                    String                       @id @default(cuid())
  assessmentPeriodId    String
  parameterId           Int
  parameterLabel        String
  criteriaCode          String
  criteriaLabel         String
  criteriaScore         Decimal                      @db.Decimal(10, 2)
  aoi                   String
  sortOrder             Int                          @default(0)
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  reviewNotes           String?
  reviewStatus          String                       @default("pending")
  reviewedAt            DateTime?
  reviewedById          String?
  createdByName         String?
  createdByRole         String?
  isRevision            Boolean?                     @default(false)
  previousAoi           String?
  previousCriteriaCode  String?
  previousCriteriaLabel String?
  previousCriteriaScore Decimal?                     @db.Decimal(10, 2)
  previousDocuments     Json?
  revisionNumber        Int?
  assessmentPeriod      AssessmentPeriod             @relation(fields: [assessmentPeriodId], references: [id], onDelete: Cascade)
  reviewedBy            User?                        @relation("AssessmentResponseReviewer", fields: [reviewedById], references: [id])
  documentLinks         AssessmentResponseDocument[]
  followUps             FollowUpEntry[]

  @@index([assessmentPeriodId])
  @@index([parameterId])
  @@index([sortOrder])
  @@index([reviewStatus])
  @@index([reviewedById])
}

model AssessmentDocument {
  id                 String                       @id @default(cuid())
  assessmentPeriodId String
  uploadedById       String?
  sourceParameter    String?
  name               String
  originalName       String
  mimeType           String
  fileExtension      String?
  fileSize           Int
  storageProvider    StorageProvider              @default(DATABASE)
  checksumSha256     String?
  fileData           Bytes
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  isMaster           Boolean                      @default(false)
  assessmentPeriod   AssessmentPeriod             @relation(fields: [assessmentPeriodId], references: [id], onDelete: Cascade)
  uploadedBy         User?                        @relation("DocumentUploader", fields: [uploadedById], references: [id])
  responseLinks      AssessmentResponseDocument[]
  followUpLinks      FollowUpEntryDocument[]

  @@index([assessmentPeriodId])
  @@index([isMaster])
}

model AssessmentResponseDocument {
  responseId String
  documentId String
  createdAt  DateTime           @default(now())
  document   AssessmentDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  response   AssessmentResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@id([responseId, documentId])
  @@index([documentId])
  @@index([responseId])
}

model FollowUpEntry {
  id                   String                  @id @default(cuid())
  assessmentResponseId String
  description          String
  sortOrder            Int                     @default(0)
  createdById          String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  followUpStatus       FollowUpStatus          @default(DONE)
  pendingReason        String?
  assessmentResponse   AssessmentResponse      @relation(fields: [assessmentResponseId], references: [id], onDelete: Cascade)
  createdBy            User?                   @relation("FollowUpCreator", fields: [createdById], references: [id])
  documents            FollowUpEntryDocument[]

  @@index([assessmentResponseId])
  @@index([followUpStatus])
  @@index([createdById])
}

model FollowUpEntryDocument {
  followUpEntryId String
  documentId      String
  createdAt       DateTime           @default(now())
  document        AssessmentDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  followUpEntry   FollowUpEntry      @relation(fields: [followUpEntryId], references: [id], onDelete: Cascade)

  @@id([followUpEntryId, documentId])
  @@index([documentId])
  @@index([followUpEntryId])
}

model AuditLog {
  id            String        @id @default(cuid())
  actorId       String?
  action        String
  entityType    String
  entityId      String
  severity      AuditSeverity @default(INFO)
  ipAddress     String?
  userAgent     String?
  requestId     String?
  previousState Json?
  nextState     Json?
  metadata      Json?
  createdAt     DateTime      @default(now())
  actor         User?         @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([actorId, createdAt])
}

model GuideDocument {
  id             String        @id @default(cuid())
  name           String
  description    String?
  originalName   String
  mimeType       String
  fileExtension  String?
  fileSize       Int
  checksumSha256 String?
  fileData       Bytes
  isActive       Boolean       @default(true)
  uploadedById   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  category       GuideCategory @default(PETUNJUK_TOOLS)
  uploadedBy     User?         @relation("GuideDocumentUploader", fields: [uploadedById], references: [id])

  @@index([category])
  @@index([category, isActive])
  @@index([isActive, createdAt])
  @@index([uploadedById])
}

enum UserRole {
  SUPER_ADMIN
  BPKP_ADMIN
  BPKP_REVIEWER
  BLUD_ADMIN
  BLUD_OPERATOR
  AUDITOR
  BLU_ADMIN
  BLU_OPERATOR
}

enum AssessmentStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  REVISION_REQUESTED
  APPROVED
  REJECTED
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum StorageProvider {
  DATABASE
}

enum GuideCategory {
  PETUNJUK_TOOLS
  PERATURAN_MR
  BAHAN_PEMBELAJARAN
  CONTOH_DOKUMEN
}

enum FollowUpStatus {
  DONE
  NOT_DONE
}
